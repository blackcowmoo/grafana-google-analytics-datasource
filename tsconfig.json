{
  "extends": "./.config/tsconfig.json",
  "compilerOptions": {
    "target": "es5",
    "lib": ["DOM", "ES2015"],
    "jsx": "react",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "types": ["react", "lodash"],
    "typeRoots": ["./node_modules/@types"],
    "baseUrl": "./src",
    "paths": {
      "@grafana/data": ["node_modules/@grafana/data"],
      "@grafana/runtime": ["node_modules/@grafana/runtime"],
      "@grafana/ui": ["node_modules/@grafana/ui"]
    }
  },
  "include": ["src", "types"]
}
